{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true
  },
  "include": [
    "capacitor.config.ts",
    "cypress/**/*.ts",
    "cypress.config.ts",
    "packages/render/src/**/*.ts",
    "src/ts/modules/**/*.ts",
    "src/ts/plugins/**/*.ts",
    "src/ts/types/**/*.ts",
    "vite.config.ts",
    "vitest.config.ts",
    "vitest.property.config.ts"
  ],
  "exclude": ["node_modules", "dist", "build", "src/ts/index.ts"]
}
